### Variables 
@apiurl = http://localhost:3500/api
@tableName = inscricoes

### GET inscricoes
GET {{apiurl}}/{{tableName}} HTTP/1.1

###
GET {{apiurl}}/{{tableName}}/1

###
POST {{apiurl}}/{{tableName}}
Content-Type: application/json; charset=utf-8

{
  "id_usuario": 6,
  "id_curso": 6 ,
  "email": "teste@gmail.com" ,
  "nome": "Luiz",
  "modalidade":"Presencial"
  }

###
DELETE {{apiurl}}/{{tableName}}/2

###
PUT {{apiurl}}/{{tableName}}/1
Content-Type: application/json; charset=utf-8

{
    "titulo": "Sistemas para Internet",
    "descricao": "Foque no desenvolvimento de aplicações web, websites e sistemas interativos, da concepção à implantação no ambiente online.",
    "url": "https://fatectq.cps.sp.gov.br",
    "preco": 0 ,
    "plataforma":"Fatec Taquaritinga"
  }