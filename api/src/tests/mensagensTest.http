### Variables 
@apiurl = http://localhost:3500/api
@tableName = mensagens

### GET mensagens
GET {{apiurl}}/{{tableName}} HTTP/1.1

###
GET {{apiurl}}/{{tableName}}/1

###
POST {{apiurl}}/{{tableName}}
Content-Type: application/json; charset=utf-8

{
  "id_grupo": 1 ,
  "id_usuario": 1,
  "mensagem": "teste" ,
  "data_envio": ""    
}

###
DELETE {{apiurl}}/{{tableName}}/2

###
PUT {{apiurl}}/{{tableName}}/1
Content-Type: application/json; charset=utf-8

{
  "id_grupo": 1 ,
  "id_usuario": 1,
  "mensagem": "teste 2" ,
  "data_envio": ""    
}